{
  "name": "nusmods-mcp",
  "version": "0.1.0",
  "description": "MCP server for NUSMods course search and deterministic timetable planning.",
  "type": "module",
  "bin": {
    "nusmods-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nusmods",
    "timetable",
    "nus"
  ],
  "license": "MIT"
}
